{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "muscle _host-hook --platform claude-code --event session_start || true",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "muscle _host-hook --platform claude-code --event user_prompt_submit || true",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "muscle _host-hook --platform claude-code --event stop || true",
            "timeout": 150
          }
        ]
      }
    ]
  }
}
